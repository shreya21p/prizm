# ============================================================
#  PRIZM — API KEY CONFIGURATION (GROQ EDITION)
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to git (it is already in .gitignore).
# ============================================================

# ------------------------------------
# STAGE 1 — Source Check
# Uses KEY_01 (dedicated, not shared with persona pool)
# ------------------------------------
GROQ_KEY_01=YOUR_GROQ_KEY_01_HERE

# ------------------------------------
# STAGE 2 — 12 Persona Calls (round-robin pool)
# Keys 02-13 are shared across all 12 persona calls.
# Add more keys simply by incrementing the suffix.
# The router picks the next available key automatically.
# ------------------------------------
GROQ_KEY_02=YOUR_GROQ_KEY_02_HERE
GROQ_KEY_03=YOUR_GROQ_KEY_03_HERE
GROQ_KEY_04=YOUR_GROQ_KEY_04_HERE
GROQ_KEY_05=YOUR_GROQ_KEY_05_HERE
GROQ_KEY_06=YOUR_GROQ_KEY_06_HERE
GROQ_KEY_07=YOUR_GROQ_KEY_07_HERE
GROQ_KEY_08=YOUR_GROQ_KEY_08_HERE
GROQ_KEY_09=YOUR_GROQ_KEY_09_HERE
GROQ_KEY_10=YOUR_GROQ_KEY_10_HERE
GROQ_KEY_11=YOUR_GROQ_KEY_11_HERE
GROQ_KEY_12=YOUR_GROQ_KEY_12_HERE
GROQ_KEY_13=YOUR_GROQ_KEY_13_HERE

# ------------------------------------
# SERVER CONFIG (optional, sensible defaults shown)
# ------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
